  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        {
          "name": "✅ Login - Valid Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has success true', function() {",
                  "  pm.expect(pm.response.json().success).to.equal(true);",
                  "});",
                  "",
                  "pm.test('Response contains user data', function() {",
                  "  pm.expect(pm.response.json().data).to.have.keys('id', 'email', 'role');",
                  "});",
                  "",
                  "// Save auth_token from cookies",
                  "var cookies = pm.response.cookies;",
                  "var authCookie = cookies.get('auth_token');",
                  "if (authCookie) {",
                  "  pm.environment.set('auth_token', authCookie);",
                  "  pm.test('Auth token cookie set', function() {",
                  "    pm.expect(authCookie).to.be.truthy();",
                  "  });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\\n  \\\"email\\\": \\\"admin@ems.com\\\",\\n  \\\"password\\\": \\\"Admin@123\\\"\\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
